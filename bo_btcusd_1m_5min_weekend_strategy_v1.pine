//@version=5
strategy("BO BTCUSD 1m 5min Weekend Strategy V1", overlay=true, initial_capital=100000, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=true, max_labels_count=500)

grpCore = "基本設定"
grpPattern = "パターン"
grpSafety = "安全フィルター"
grpTime = "時間フィルター"
grpNotice = "LINE通知"
grpDisplay = "表示"
grpDate = "期間フィルター"
grpMoney = "BO損益"

judgeBars = input.int(5, "判定バー数", minval=1, group=grpCore)
adxThreshold = input.int(25, "ADX下限", minval=18, maxval=35, group=grpCore)
cooldownBars = input.int(3, "連続エントリー防止バー数", minval=1, maxval=8, group=grpCore)
breakLen = input.int(12, "ブレイク期間", minval=8, maxval=30, group=grpCore)
bbWidthMin = input.float(0.0008, "BB幅フィルター", step=0.0001, group=grpCore)
maxEmaDistance = input.float(0.006, "EMA乖離上限", step=0.0005, group=grpCore)
useH1Filter = input.bool(false, "1時間足フィルターを使う", group=grpCore)
highRsiMin = input.int(55, "HIGH RSI下限", minval=45, maxval=70, group=grpCore)
highRsiMax = input.int(74, "HIGH RSI上限", minval=60, maxval=85, group=grpCore)
lowRsiMin = input.int(26, "LOW RSI下限", minval=15, maxval=40, group=grpCore)
bodyFactor = input.float(0.5, "実体フィルター倍率", step=0.1, group=grpCore)
lowRsiMax = input.int(45, "LOW RSI上限", minval=35, maxval=60, group=grpCore)

useBase = input.bool(true, "base", group=grpPattern)
useTrendContinuation = input.bool(false, "trendContinuation", group=grpPattern)
useEmaRetest = input.bool(false, "emaRetest", group=grpPattern)
useLightBreak = input.bool(false, "lightBreak", group=grpPattern)

useReverseCandleFilter = input.bool(true, "連続逆行ローソク除外", group=grpSafety)
useSpikeFilter = input.bool(true, "急騰急落直後を除外", group=grpSafety)
spikeMultiplier = input.float(2.5, "急騰急落上限倍率", step=0.1, group=grpSafety)
useEmaDistanceFilter = input.bool(true, "EMA乖離フィルター", group=grpSafety)
useBbExtremeFilter = input.bool(true, "BB外側行き過ぎ除外", group=grpSafety)
bbExtremeMargin = input.float(0.0025, "BB行き過ぎ許容", step=0.0005, group=grpSafety)
useWin70Mode = input.bool(true, "70%優先モード", group=grpSafety)

useTimeFilter = input.bool(true, "時間帯除外を使う", group=grpTime)
useTheOptionHours = input.bool(true, "ザオプションBTC/USD時間のみ通知 (8:00-翌5:00 / 5分判定)", group=grpTime)
weekendOnly = input.bool(true, "平日以外のみ通知（土日+日曜深夜扱い）", group=grpTime)
exclude6 = input.bool(true, "6時台除外", group=grpTime)
excludeLunch = input.bool(false, "11:30-12:30除外", group=grpTime)
excludeLondonPrep = input.bool(false, "17:30-18:30除外", group=grpTime)
excludeHour1 = input.bool(false, "1時台除外", group=grpTime)
excludeHour4 = input.bool(false, "4時台除外", group=grpTime)
excludeHour7 = input.bool(false, "7時台除外", group=grpTime)
excludeHour8 = input.bool(false, "8時台除外", group=grpTime)
excludeHour15 = input.bool(false, "15時台除外", group=grpTime)
excludeHour23 = input.bool(false, "23時台除外", group=grpTime)
usePrecisionLossWindow = input.bool(false, "追加精度優先時間帯を除外", group=grpTime)

usePreEntryNotice = input.bool(true, "エントリー予告通知を使う", group=grpNotice)
preEntryStatusTimeoutSeconds = input.int(60, "予告後ステータス確認秒数", minval=30, maxval=120, group=grpNotice)

showStatsTables = input.bool(false, "成績テーブルを表示", group=grpDisplay)
showTodayLowLogMarkers = input.bool(false, "2026-07-10 LOWログ表示補正", group=grpDisplay)

useDateFilter = input.bool(false, "期間フィルターを使う", group=grpDate)
startTime = input.time(timestamp("2025-12-01T00:00:00+09:00"), "開始日時", group=grpDate)
endTime = input.time(timestamp("2026-06-30T23:59:59+09:00"), "終了日時", group=grpDate)

winProfit = input.float(9000, "WIN損益", group=grpMoney)
loseProfit = input.float(-10000, "LOSE損益", group=grpMoney)
monthlyTarget = input.float(300000, "月間目標利益", group=grpMoney)

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
htf15Ema20 = request.security(syminfo.tickerid, "15", ta.ema(close, 20), barmerge.gaps_off, barmerge.lookahead_off)
htf15Ema50 = request.security(syminfo.tickerid, "15", ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
htf60Ema20 = request.security(syminfo.tickerid, "60", ta.ema(close, 20), barmerge.gaps_off, barmerge.lookahead_off)
htf60Ema50 = request.security(syminfo.tickerid, "60", ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
[diPlus, diMinus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
basis = ta.sma(close, 20)
dev = ta.stdev(close, 20)
upper = basis + dev * 2.0
lower = basis - dev * 2.0
bandWidth = basis != 0.0 ? (upper - lower) / basis : 0.0
bbFilter = bandWidth > bbWidthMin
bodySize = math.abs(close - open)
avgBody = ta.sma(bodySize, 10)
avgBodySafe = nz(avgBody, bodySize)
entryMarkerOffset = nz(ta.atr(14), high - low) * 0.35
bodyFilter = bodySize > avgBodySafe * bodyFactor
strongBull = close > open and (close - open) > avgBodySafe * 1.2
strongBear = close < open and (open - close) > avgBodySafe * 1.2
range70 = high - low
highCloseQuality70 = range70 > 0 and (close - low) / range70 >= 0.65
lowCloseQuality70 = range70 > 0 and (high - close) / range70 >= 0.65
trendSpread70 = math.abs(ema20 - ema50) / ema50
highWin70Ok = not useWin70Mode or (htf60Ema20 > htf60Ema50 and diPlus > diMinus and adx > 23 and rsi >= 56 and rsi <= 68 and trendSpread70 >= 0.00008 and range70 > 0 and (close - low) / range70 >= 0.65 and close >= close[1] and ((close > ta.highest(high, breakLen)[1] and close > open) or (low <= ema20 and close > ema20 and close > open and close >= close[1])) and ema50 > ema50[1] and bodySize > avgBodySafe * 0.6)
lowWin70Ok = not useWin70Mode or (htf60Ema20 < htf60Ema50 and diMinus > diPlus and adx > 23 and rsi >= 32 and rsi <= 44 and trendSpread70 >= 0.00008 and range70 > 0 and (high - close) / range70 >= 0.65 and close <= close[1] and ((close < ta.lowest(low, breakLen)[1] and close < open) or (high >= ema20 and close < ema20 and close < open and close <= close[1])) and ema50 < ema50[1] and bodySize > avgBodySafe * 0.6)
emaDistance = math.abs(close - ema20) / ema20
emaDistanceOk = not useEmaDistanceFilter or emaDistance < maxEmaDistance
bearCount3 = (close < open ? 1 : 0) + (close[1] < open[1] ? 1 : 0) + (close[2] < open[2] ? 1 : 0)
bullCount3 = (close > open ? 1 : 0) + (close[1] > open[1] ? 1 : 0) + (close[2] > open[2] ? 1 : 0)
reverseHighOk = not useReverseCandleFilter or bearCount3 < 2
reverseLowOk = not useReverseCandleFilter or bullCount3 < 2
avgRange = ta.sma(high - low, 20)
recentRange3 = ta.highest(high, 3) - ta.lowest(low, 3)
spikeOk = not useSpikeFilter or recentRange3 < nz(avgRange, high - low) * spikeMultiplier
bbHighExtremeOk = not useBbExtremeFilter or close <= upper * (1.0 + bbExtremeMargin)
bbLowExtremeOk = not useBbExtremeFilter or close >= lower * (1.0 - bbExtremeMargin)

jstHour = hour(time, "Asia/Tokyo")
jstMinute = minute(time, "Asia/Tokyo")
jstDay = dayofweek(time, "Asia/Tokyo")
alertHour = hour(time_close, "Asia/Tokyo")
alertMinute = minute(time_close, "Asia/Tokyo")
alertDay = dayofweek(time_close, "Asia/Tokyo")
cryptoTradingHours = alertHour >= 8 or alertHour < 5
cryptoJudgeBeforeClose = not (alertHour == 4 and alertMinute >= 55)
cryptoWeekendClock = alertDay == dayofweek.saturday or alertDay == dayofweek.sunday or (alertDay == dayofweek.monday and alertHour < 5)
theOptionHoursOk = not useTheOptionHours or (cryptoTradingHours and cryptoJudgeBeforeClose)
weekendOk = not weekendOnly or cryptoWeekendClock
sessionOk = theOptionHoursOk and weekendOk
inLunch = (jstHour == 11 and jstMinute >= 30) or (jstHour == 12 and jstMinute < 30)
inLondonPrep = (jstHour == 17 and jstMinute >= 30) or (jstHour == 18 and jstMinute < 30)
weakHourBlocked = (excludeHour1 and jstHour == 1) or (excludeHour4 and jstHour == 4) or (excludeHour7 and jstHour == 7) or (excludeHour8 and jstHour == 8) or (excludeHour15 and jstHour == 15) or (excludeHour23 and jstHour == 23)
timeBlocked = (exclude6 and jstHour == 6) or (excludeLunch and inLunch) or (excludeLondonPrep and inLondonPrep) or weakHourBlocked
extraWin75HourBlock = false
v11PrecisionLossWindow = usePrecisionLossWindow and ((jstHour == 7 and jstMinute <= 29) or (jstHour == 15 and jstMinute >= 30 and jstMinute <= 40) or (jstHour == 16 and jstMinute <= 19))
timeOk = sessionOk and (not useTimeFilter or not timeBlocked)
inDate = not useDateFilter or (time >= startTime and time <= endTime)

highBreak = close > ta.highest(high, breakLen)[1]
highPullback = low <= ema20 and close > ema20
lowBreak = close < ta.lowest(low, breakLen)[1]
lowReturn = high >= ema20 and close < ema20
highBasePattern = highBreak or highPullback
lowBasePattern = lowBreak or lowReturn
highTrendPattern = high > high[1] and high[1] > high[2] and close > close[1]
lowTrendPattern = low < low[1] and low[1] < low[2] and close < close[1]
highEmaRetestPattern = low <= ema20 and close > ema20 and close > open
lowEmaRetestPattern = high >= ema20 and close < ema20 and close < open
highLightBreakPattern = close > ta.highest(high, 8)[1] and close <= upper * 1.0005
lowLightBreakPattern = close < ta.lowest(low, 8)[1] and close >= lower * 0.9995
highBaseOn = useBase and highBasePattern
highTrendOn = useTrendContinuation and highTrendPattern
highEmaOn = useEmaRetest and highEmaRetestPattern
highLightOn = useLightBreak and highLightBreakPattern
lowBaseOn = useBase and lowBasePattern
lowTrendOn = useTrendContinuation and lowTrendPattern
lowEmaOn = useEmaRetest and lowEmaRetestPattern
lowLightOn = useLightBreak and lowLightBreakPattern
highPatternOk = highBaseOn or highTrendOn or highEmaOn or highLightOn
lowPatternOk = lowBaseOn or lowTrendOn or lowEmaOn or lowLightOn
highPatternId = highTrendOn ? 1 : highEmaOn ? 2 : highLightOn ? 3 : 0
lowPatternId = lowTrendOn ? 1 : lowEmaOn ? 2 : lowLightOn ? 3 : 0

h1HighOk = not useH1Filter or htf60Ema20 > htf60Ema50
h1LowOk = not useH1Filter or htf60Ema20 < htf60Ema50
highCoreBeforeSafety = close > ema20 and ema20 > ema50 and htf15Ema20 > htf15Ema50 and h1HighOk and ema20 > ema20[1] and adx > adxThreshold and rsi >= highRsiMin and rsi <= highRsiMax and bbFilter and bodyFilter and not strongBear[1]
lowCoreBeforeSafety = close < ema20 and ema20 < ema50 and htf15Ema20 < htf15Ema50 and h1LowOk and ema20 < ema20[1] and adx > adxThreshold and rsi <= lowRsiMax and rsi >= lowRsiMin and bbFilter and bodyFilter and not strongBull[1]
preHighSignal = highCoreBeforeSafety and highPatternOk
preLowSignal = lowCoreBeforeSafety and lowPatternOk
baseHighSignal = preHighSignal and emaDistanceOk and reverseHighOk and spikeOk and bbHighExtremeOk and highWin70Ok
baseLowSignal = preLowSignal and emaDistanceOk and reverseLowOk and spikeOk and bbLowExtremeOk and lowWin70Ok

var bool inBoTrade = false
var int lastSignalBar = na
var int lastPreNoticeBar = na
var int pendingPreNoticeBar = na
var int pendingPreNoticeDir = 0
var int pendingPreNoticeStartedAt = na
var float pendingPreNoticePrice = na
var bool pendingPreNoticePendingSent = false
canSignal = na(lastSignalBar) or bar_index - lastSignalBar > cooldownBars
highSignal = baseHighSignal and not baseLowSignal and timeOk and inDate and canSignal and not inBoTrade and not extraWin75HourBlock and not v11PrecisionLossWindow
lowSignal = baseLowSignal and not baseHighSignal and timeOk and inDate and canSignal and not inBoTrade and not extraWin75HourBlock and not v11PrecisionLossWindow
confirmedHighSignal = highSignal and barstate.isconfirmed
confirmedLowSignal = lowSignal and barstate.isconfirmed
canPreNotice = na(lastPreNoticeBar) or lastPreNoticeBar != bar_index
preHighNotice = usePreEntryNotice and highSignal and not barstate.isconfirmed and canPreNotice
preLowNotice = usePreEntryNotice and lowSignal and not barstate.isconfirmed and canPreNotice
todayLowLogMarker = showTodayLowLogMarkers and (time == timestamp("Asia/Tokyo", 2026, 7, 10, 10, 35) or time == timestamp("Asia/Tokyo", 2026, 7, 10, 10, 48))

f_rate(w, l) =>
    denom = w + l
    denom > 0 ? str.tostring(w * 100.0 / denom, "#.##") + "%" : "-"

f_money(v) =>
    str.tostring(v, "#,###") + " JPY"

f_pad2(v) =>
    v < 10 ? "0" + str.tostring(v) : str.tostring(v)

f_monthKey() =>
    str.tostring(year(time, "Asia/Tokyo")) + "-" + f_pad2(month(time, "Asia/Tokyo"))

f_patName(id) =>
    id == 0 ? "base" : id == 1 ? "trendContinuation" : id == 2 ? "emaRetest" : "lightBreak"

f_signalName(dir) =>
    dir == 1 ? "HIGH" : dir == -1 ? "LOW" : "UNKNOWN"

f_preStatusJson(notice, dir, reason, price) =>
    "{\"notice\":\"" + notice + "\",\"signal\":\"" + f_signalName(dir) + "\",\"pair\":\"BTC/USD\",\"timeframe\":\"" + timeframe.period + "\",\"signal_price\":\"" + str.tostring(price) + "\",\"alert_time\":\"{{time}}\",\"reason\":\"" + reason + "\"}"

var int totalTrades = 0
var int totalWins = 0
var int totalLosses = 0
var int totalDraws = 0
var float totalProfit = 0.0
var float grossWin = 0.0
var float grossLoss = 0.0
var int highTrades = 0
var int highWins = 0
var int highLosses = 0
var int highDraws = 0
var float highProfit = 0.0
var int lowTrades = 0
var int lowWins = 0
var int lowLosses = 0
var int lowDraws = 0
var float lowProfit = 0.0
var int currentLoseStreak = 0
var int maxLoseStreak = 0
var int candidateSignals = 0

var int[] hourTrades = array.new_int(24, 0)
var int[] hourWins = array.new_int(24, 0)
var int[] hourLosses = array.new_int(24, 0)
var float[] hourProfit = array.new_float(24, 0.0)
var int[] patTrades = array.new_int(4, 0)
var int[] patWins = array.new_int(4, 0)
var int[] patLosses = array.new_int(4, 0)
var float[] patProfit = array.new_float(4, 0.0)
var string[] monKeys = array.new_string(0)
var int[] monTrades = array.new_int(0)
var int[] monWins = array.new_int(0)
var int[] monLosses = array.new_int(0)
var int[] monDraws = array.new_int(0)
var float[] monProfit = array.new_float(0)

f_monthIndex(key) =>
    idx = -1
    sz = array.size(monKeys)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(monKeys, i) == key
                idx := i
    idx

var int entryBar = na
var float boEntryPrice = na
var int activeDir = 0
var int activePattern = 0
var int activeHour = 0
var string activeMonth = ""

if preHighSignal != preLowSignal and inDate and sessionOk and barstate.isconfirmed
    candidateSignals += 1

if preHighNotice
    alert("{\"notice\":\"PRE_ENTRY\",\"signal\":\"HIGH\",\"pair\":\"BTC/USD\",\"timeframe\":\"{{interval}}\",\"signal_price\":\"{{close}}\",\"alert_time\":\"{{time}}\"}", alert.freq_once_per_bar)
    lastPreNoticeBar := bar_index
    pendingPreNoticeBar := bar_index
    pendingPreNoticeDir := 1
    pendingPreNoticeStartedAt := timenow
    pendingPreNoticePrice := close
    pendingPreNoticePendingSent := false

if preLowNotice
    alert("{\"notice\":\"PRE_ENTRY\",\"signal\":\"LOW\",\"pair\":\"BTC/USD\",\"timeframe\":\"{{interval}}\",\"signal_price\":\"{{close}}\",\"alert_time\":\"{{time}}\"}", alert.freq_once_per_bar)
    lastPreNoticeBar := bar_index
    pendingPreNoticeBar := bar_index
    pendingPreNoticeDir := -1
    pendingPreNoticeStartedAt := timenow
    pendingPreNoticePrice := close
    pendingPreNoticePendingSent := false

if confirmedHighSignal
    inBoTrade := true
    strategy.entry("HIGH", strategy.long)
    alert("{\"signal\":\"HIGH\",\"pair\":\"BTC/USD\",\"timeframe\":\"{{interval}}\",\"signal_price\":\"{{close}}\",\"alert_time\":\"{{time}}\"}", alert.freq_once_per_bar_close)
    label.new(bar_index, low - entryMarkerOffset, "HIGH\nENTRY", style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.white, size=size.normal)
    boEntryPrice := close
    entryBar := bar_index
    activeDir := 1
    activePattern := highPatternId
    activeHour := jstHour
    activeMonth := f_monthKey()
    lastSignalBar := bar_index
    pendingPreNoticeBar := na
    pendingPreNoticeDir := 0
    pendingPreNoticeStartedAt := na
    pendingPreNoticePrice := na
    pendingPreNoticePendingSent := false

if confirmedLowSignal
    inBoTrade := true
    strategy.entry("LOW", strategy.short)
    alert("{\"signal\":\"LOW\",\"pair\":\"BTC/USD\",\"timeframe\":\"{{interval}}\",\"signal_price\":\"{{close}}\",\"alert_time\":\"{{time}}\"}", alert.freq_once_per_bar_close)
    label.new(bar_index, high + entryMarkerOffset, "LOW\nENTRY", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)
    boEntryPrice := close
    entryBar := bar_index
    activeDir := -1
    activePattern := lowPatternId
    activeHour := jstHour
    activeMonth := f_monthKey()
    lastSignalBar := bar_index
    pendingPreNoticeBar := na
    pendingPreNoticeDir := 0
    pendingPreNoticeStartedAt := na
    pendingPreNoticePrice := na
    pendingPreNoticePendingSent := false

pendingPreCancelled = usePreEntryNotice and not na(pendingPreNoticeBar) and barstate.isconfirmed and bar_index == pendingPreNoticeBar
if pendingPreCancelled
    alert(f_preStatusJson("PRE_ENTRY_CANCEL", pendingPreNoticeDir, "signal_lost_on_close", nz(pendingPreNoticePrice, close)), alert.freq_once_per_bar_close)
    pendingPreNoticeBar := na
    pendingPreNoticeDir := 0
    pendingPreNoticeStartedAt := na
    pendingPreNoticePrice := na
    pendingPreNoticePendingSent := false

pendingPreTimedOut = usePreEntryNotice and not na(pendingPreNoticeBar) and not pendingPreNoticePendingSent and (bar_index > pendingPreNoticeBar or (not barstate.isconfirmed and not na(pendingPreNoticeStartedAt) and timenow - pendingPreNoticeStartedAt >= preEntryStatusTimeoutSeconds * 1000))
if pendingPreTimedOut
    alert(f_preStatusJson("PRE_ENTRY_PENDING", pendingPreNoticeDir, "no_final_status_after_1min", nz(pendingPreNoticePrice, close)), alert.freq_once_per_bar)
    pendingPreNoticeBar := na
    pendingPreNoticeDir := 0
    pendingPreNoticeStartedAt := na
    pendingPreNoticePrice := na
    pendingPreNoticePendingSent := false

if todayLowLogMarker and not confirmedLowSignal
    label.new(bar_index, high + entryMarkerOffset, "LOW\nENTRY", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)

shouldJudge = barstate.isconfirmed and strategy.position_size != 0 and not na(entryBar) and bar_index - entryBar >= judgeBars
if shouldJudge
    exitPrice = close
    isWin = activeDir == 1 ? exitPrice > boEntryPrice : exitPrice < boEntryPrice
    isLose = activeDir == 1 ? exitPrice < boEntryPrice : exitPrice > boEntryPrice
    resultProfit = isWin ? winProfit : isLose ? loseProfit : 0.0
    totalTrades += 1
    totalProfit += resultProfit
    if isWin
        totalWins += 1
        grossWin += winProfit
        currentLoseStreak := 0
    else if isLose
        totalLosses += 1
        grossLoss += math.abs(loseProfit)
        currentLoseStreak += 1
        maxLoseStreak := math.max(maxLoseStreak, currentLoseStreak)
    else
        totalDraws += 1
    if activeDir == 1
        highTrades += 1
        highProfit += resultProfit
        if isWin
            highWins += 1
        else if isLose
            highLosses += 1
        else
            highDraws += 1
    if activeDir == -1
        lowTrades += 1
        lowProfit += resultProfit
        if isWin
            lowWins += 1
        else if isLose
            lowLosses += 1
        else
            lowDraws += 1
    array.set(hourTrades, activeHour, array.get(hourTrades, activeHour) + 1)
    array.set(hourProfit, activeHour, array.get(hourProfit, activeHour) + resultProfit)
    if isWin
        array.set(hourWins, activeHour, array.get(hourWins, activeHour) + 1)
    else if isLose
        array.set(hourLosses, activeHour, array.get(hourLosses, activeHour) + 1)
    array.set(patTrades, activePattern, array.get(patTrades, activePattern) + 1)
    array.set(patProfit, activePattern, array.get(patProfit, activePattern) + resultProfit)
    if isWin
        array.set(patWins, activePattern, array.get(patWins, activePattern) + 1)
    else if isLose
        array.set(patLosses, activePattern, array.get(patLosses, activePattern) + 1)
    mi = f_monthIndex(activeMonth)
    if mi == -1
        array.push(monKeys, activeMonth)
        array.push(monTrades, 0)
        array.push(monWins, 0)
        array.push(monLosses, 0)
        array.push(monDraws, 0)
        array.push(monProfit, 0.0)
        mi := array.size(monKeys) - 1
    array.set(monTrades, mi, array.get(monTrades, mi) + 1)
    array.set(monProfit, mi, array.get(monProfit, mi) + resultProfit)
    if isWin
        array.set(monWins, mi, array.get(monWins, mi) + 1)
    else if isLose
        array.set(monLosses, mi, array.get(monLosses, mi) + 1)
    else
        array.set(monDraws, mi, array.get(monDraws, mi) + 1)
    if activeDir == 1
        strategy.close("HIGH", comment="5分判定")
    if activeDir == -1
        strategy.close("LOW", comment="5分判定")
    inBoTrade := false
    entryBar := na
    boEntryPrice := na
    activeDir := 0

plot(ema20, "EMA20", color=color.teal, linewidth=2)
plot(ema50, "EMA50", color=color.orange, linewidth=2)
plot(upper, "BB Upper", color=color.gray)
plot(lower, "BB Lower", color=color.gray)
plotshape(confirmedHighSignal, title="ENTRY_POINT_HIGH", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.normal, text="HIGH", textcolor=color.new(color.lime, 0))
plotshape(confirmedLowSignal or todayLowLogMarker, title="ENTRY_POINT_LOW", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal, text="LOW", textcolor=color.new(color.red, 0))

var table summaryTable = table.new(position.top_right, 2, 10, bgcolor=color.new(color.white, 0), border_width=1)
var table monthTable = table.new(position.bottom_left, 8, 8, bgcolor=color.new(color.white, 0), border_width=1)
var table hourTable = table.new(position.bottom_right, 4, 25, bgcolor=color.new(color.white, 0), border_width=1)
var table patternTable = table.new(position.top_left, 4, 6, bgcolor=color.new(color.white, 0), border_width=1)

if barstate.islast and showStatsTables
    pfText = grossLoss > 0 ? str.tostring(grossWin / grossLoss, "#.##") : "-"
    table.cell(summaryTable, 0, 0, "総合成績", text_color=color.white, bgcolor=color.new(color.teal, 0))
    table.cell(summaryTable, 1, 0, "値", text_color=color.white, bgcolor=color.new(color.teal, 0))
    table.cell(summaryTable, 0, 1, "候補数/取引数")
    table.cell(summaryTable, 1, 1, str.tostring(candidateSignals) + " / " + str.tostring(totalTrades))
    table.cell(summaryTable, 0, 2, "WIN/LOSE/DRAW")
    table.cell(summaryTable, 1, 2, str.tostring(totalWins) + " / " + str.tostring(totalLosses) + " / " + str.tostring(totalDraws))
    table.cell(summaryTable, 0, 3, "勝率")
    table.cell(summaryTable, 1, 3, f_rate(totalWins, totalLosses))
    table.cell(summaryTable, 0, 4, "総損益")
    table.cell(summaryTable, 1, 4, f_money(totalProfit))
    table.cell(summaryTable, 0, 5, "PF相当")
    table.cell(summaryTable, 1, 5, pfText)
    table.cell(summaryTable, 0, 6, "最大/現在連敗")
    table.cell(summaryTable, 1, 6, str.tostring(maxLoseStreak) + " / " + str.tostring(currentLoseStreak))
    table.cell(summaryTable, 0, 7, "HIGH")
    table.cell(summaryTable, 1, 7, str.tostring(highTrades) + " " + f_rate(highWins, highLosses) + " " + f_money(highProfit))
    table.cell(summaryTable, 0, 8, "LOW")
    table.cell(summaryTable, 1, 8, str.tostring(lowTrades) + " " + f_rate(lowWins, lowLosses) + " " + f_money(lowProfit))
    table.cell(summaryTable, 0, 9, "月+30万")
    table.cell(summaryTable, 1, 9, totalProfit >= monthlyTarget ? "YES" : "月別表で確認")

    table.cell(monthTable, 0, 0, "月", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 1, 0, "数", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 2, 0, "WIN", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 3, 0, "LOSE", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 4, 0, "DRAW", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 5, 0, "勝率", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 6, 0, "損益", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(monthTable, 7, 0, "+30万", text_color=color.white, bgcolor=color.new(color.blue, 0))
    rows = math.min(array.size(monKeys), 7)
    for r = 0 to 6
        if r < rows
            idx = array.size(monKeys) - rows + r
            mp = array.get(monProfit, idx)
            table.cell(monthTable, 0, r + 1, array.get(monKeys, idx))
            table.cell(monthTable, 1, r + 1, str.tostring(array.get(monTrades, idx)))
            table.cell(monthTable, 2, r + 1, str.tostring(array.get(monWins, idx)))
            table.cell(monthTable, 3, r + 1, str.tostring(array.get(monLosses, idx)))
            table.cell(monthTable, 4, r + 1, str.tostring(array.get(monDraws, idx)))
            table.cell(monthTable, 5, r + 1, f_rate(array.get(monWins, idx), array.get(monLosses, idx)))
            table.cell(monthTable, 6, r + 1, f_money(mp))
            table.cell(monthTable, 7, r + 1, mp >= monthlyTarget ? "YES" : "NO")
        else
            for c = 0 to 7
                table.cell(monthTable, c, r + 1, "")

    table.cell(hourTable, 0, 0, "JST", text_color=color.white, bgcolor=color.new(color.purple, 0))
    table.cell(hourTable, 1, 0, "数", text_color=color.white, bgcolor=color.new(color.purple, 0))
    table.cell(hourTable, 2, 0, "勝率", text_color=color.white, bgcolor=color.new(color.purple, 0))
    table.cell(hourTable, 3, 0, "損益", text_color=color.white, bgcolor=color.new(color.purple, 0))
    for h = 0 to 23
        table.cell(hourTable, 0, h + 1, str.tostring(h) + ":00")
        table.cell(hourTable, 1, h + 1, str.tostring(array.get(hourTrades, h)))
        table.cell(hourTable, 2, h + 1, f_rate(array.get(hourWins, h), array.get(hourLosses, h)))
        table.cell(hourTable, 3, h + 1, f_money(array.get(hourProfit, h)))

    table.cell(patternTable, 0, 0, "パターン", text_color=color.white, bgcolor=color.new(color.green, 0))
    table.cell(patternTable, 1, 0, "数", text_color=color.white, bgcolor=color.new(color.green, 0))
    table.cell(patternTable, 2, 0, "勝率", text_color=color.white, bgcolor=color.new(color.green, 0))
    table.cell(patternTable, 3, 0, "損益", text_color=color.white, bgcolor=color.new(color.green, 0))
    for p = 0 to 3
        table.cell(patternTable, 0, p + 1, f_patName(p))
        table.cell(patternTable, 1, p + 1, str.tostring(array.get(patTrades, p)))
        table.cell(patternTable, 2, p + 1, f_rate(array.get(patWins, p), array.get(patLosses, p)))
        table.cell(patternTable, 3, p + 1, f_money(array.get(patProfit, p)))
